{
  "schema": 2,
  "permissions": [
    "llm.complete",
    "chat.write_message",
    "storage.read",
    "storage.write",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:research-coach",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the Research Digest AI app open. The app generates structured research digests directly via the host LLM (anna.llm.complete) and stores approved digests via host storage. The Research Coach skill defines tone, depth selection, and the human-review protocol; follow it when responding inside this app's window. Never auto-save — present the digest and let the user approve it first.",
  "user_message_prefix_template": "[Research Digest] {user_message}",
  "tags": ["productivity", "research", "knowledge", "ai"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Research Digest AI",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 480, "h": 580 },
        "default_size": { "w": 820, "h": 700 },
        "max_size": { "w": 1400, "h": 1000 },
        "resizable": true,
        "movable": true,
        "single_instance": true,
        "icon": "icon.svg"
      }
    ],
    "host_api": {
      "tools": [],
      "chat": ["write_message"],
      "artifact": [],
      "llm": ["complete"],
      "fs": [],
      "storage": ["get", "set"],
      "prefs": [],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "img-src": ["'self'", "data:", "blob:"],
      "font-src": ["'self'", "data:"],
      "style-src": ["'self'"],
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
